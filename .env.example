# API Keys
FMP_API_KEY=your_key_here
EVDS_API_KEY=your_evds_key_here  # Free key: https://evds2.tcmb.gov.tr/index.php?/evds/userReg

# Email Configuration (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=your_email@gmail.com

# D-120 failure notification (optional). ALERT_EMAIL boşsa daily_update arızası
# yalnızca logs/failures/ altına yazılır; e-posta atılmaz. Gönderim için yukarıdaki
# SMTP_SERVER/SMTP_PORT/EMAIL_FROM/EMAIL_PASSWORD transport olarak kullanılır.
ALERT_EMAIL=

# Database
DB_PATH=data/bist_data.db

# Logging
LOG_LEVEL=INFO

# HuggingFace / Transformers — offline mode (recommended for CI + production)
# Prevents FinBERT from making API calls to HuggingFace on every model load.
# Model must be pre-downloaded once: python -c "from transformers import pipeline; pipeline('sentiment-analysis', model='ProsusAI/finbert')"
TRANSFORMERS_OFFLINE=1
