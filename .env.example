# API Keys
FMP_API_KEY=your_key_here
EVDS_API_KEY=your_evds_key_here  # Free key: https://evds2.tcmb.gov.tr/index.php?/evds/userReg

# D-170 MKK VYK API (KAP tarihsel FR/ODA bildirimleri — sadece backtest)
# Test ortami: https://apigwdev.mkk.com.tr  (Basic auth: "user:pass" format)
# Prod ortami: Bearer token — kapdestek@mkk.com.tr ile al
MKK_VYK_BASE_URL=https://apigwdev.mkk.com.tr
MKK_VYK_TOKEN=your_user:your_pass

# Email Configuration (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your_email@example.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=your_email@example.com

# D-120 failure notification (optional). ALERT_EMAIL boşsa daily_update arızası
# yalnızca logs/failures/ altına yazılır; e-posta atılmaz. Gönderim için yukarıdaki
# SMTP_SERVER/SMTP_PORT/EMAIL_FROM/EMAIL_PASSWORD transport olarak kullanılır.
ALERT_EMAIL=

# Database
DB_PATH=data/bist_data.db

# Logging
LOG_LEVEL=INFO

# HuggingFace / Transformers — offline mode (recommended for CI + production)
# Prevents FinBERT from making API calls to HuggingFace on every model load.
# Model must be pre-downloaded once: python -c "from transformers import pipeline; pipeline('sentiment-analysis', model='ProsusAI/finbert')"
TRANSFORMERS_OFFLINE=1

# D-152 GitHub Actions production workflow monitoring
# healthchecks.io ping URL (kur: scripts/setup_cloud.md §4)
HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here
# Telegram failure notifications (kur: scripts/setup_cloud.md §3)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
# POSITIONS_YAML_B64: sadece GitHub Secret olarak ekle, local .env'e ekleme
# Encode: [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("positions.yaml"))
