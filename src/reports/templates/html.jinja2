<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BIST Rapor — {{ report_date }}</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', sans-serif; background: #0f1117; color: #e0e0e0; padding: 24px; }
  h1 { color: #fff; font-size: 1.5rem; margin-bottom: 4px; }
  .meta { color: #888; font-size: 0.8rem; margin-bottom: 24px; }
  h2 { color: #90caf9; font-size: 1rem; margin: 24px 0 10px; text-transform: uppercase; letter-spacing: .05em; }
  .cards { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 24px; }
  .card { background: #1e2130; border-radius: 8px; padding: 16px 20px; min-width: 150px; }
  .card .label { font-size: 0.72rem; color: #888; text-transform: uppercase; letter-spacing: .05em; }
  .card .value { font-size: 1.4rem; font-weight: 700; margin-top: 4px; }
  .pos { color: #66bb6a; } .neg { color: #ef5350; } .neu { color: #e0e0e0; }
  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  th { background: #1e2130; color: #90caf9; text-align: right; padding: 8px 12px; font-weight: 600; }
  th:first-child, td:first-child { text-align: left; }
  td { padding: 7px 12px; text-align: right; border-bottom: 1px solid #1e2130; }
  tr:hover td { background: #1a1f2e; }
  .ticker { font-weight: 600; color: #fff; font-family: monospace; }
  .badge { display: inline-block; padding: 2px 7px; border-radius: 4px; font-size: 0.72rem; font-weight: 700; }
  .badge-high { background: #b71c1c; color: #fff; }
  .badge-med  { background: #e65100; color: #fff; }
  .badge-low  { background: #1565c0; color: #fff; }
  .alert-box { background: #1e2130; border-left: 3px solid #ef5350; border-radius: 4px; padding: 10px 14px; margin: 6px 0; font-size: 0.85rem; }
  .alert-box.med { border-color: #ffa726; }
  .alert-box.low { border-color: #42a5f5; }
  .rsi-high { color: #ef5350; font-weight: 700; }
  .rsi-low  { color: #66bb6a; font-weight: 700; }
  tr.warn td { background: #1a1208; }
  tr.warn td:first-child { border-left: 3px solid #ffa726; }
  footer { margin-top: 40px; font-size: 0.72rem; color: #555; border-top: 1px solid #1e2130; padding-top: 12px; }
</style>
</head>
<body>

<h1>BIST Günlük Rapor</h1>
<div class="meta">{{ report_date }} &nbsp;·&nbsp; {{ generated_at }} itibarıyla</div>

<h2>Portföy Özeti</h2>
<div class="cards">
  <div class="card">
    <div class="label">Toplam Maliyet</div>
    <div class="value neu">{{ total_cost|thou }} TL</div>
  </div>
  <div class="card">
    <div class="label">Piyasa Değeri</div>
    <div class="value neu">{{ total_value|thou }} TL</div>
  </div>
  <div class="card">
    <div class="label">Toplam P&L</div>
    <div class="value {{ 'pos' if total_pnl >= 0 else 'neg' }}">{{ total_pnl|tl }} TL</div>
  </div>
  <div class="card">
    <div class="label">P&L %</div>
    <div class="value {{ 'pos' if total_pnl_pct >= 0 else 'neg' }}">{{ total_pnl_pct|pct }}</div>
  </div>
</div>

<table>
  <thead>
    <tr>
      <th>Ticker</th><th>Adet</th><th>Maliyet</th><th>Son</th>
      <th>P&L%</th><th>P&L TL</th><th>RSI</th><th>vs MA20</th>
      <th>Stop-Loss</th><th>Hedef</th>
    </tr>
  </thead>
  <tbody>
  {% for p in positions %}
    {% set is_warn = p.rsi and p.rsi < 40 and p.ma20_diff is not none and p.ma20_diff < -5 %}
    <tr{% if is_warn %} class="warn"{% endif %}>
      <td class="ticker">{{ p.ticker }}</td>
      <td>{{ p.quantity }}</td>
      <td>{{ "%.2f"|format(p.avg_cost) }}</td>
      <td>{{ "%.2f"|format(p.current_price) }}</td>
      <td class="{{ 'pos' if p.pnl_pct >= 0 else 'neg' }}">{{ p.pnl_pct|pct }}</td>
      <td class="{{ 'pos' if p.pnl_tl >= 0 else 'neg' }}">{{ p.pnl_tl|tl }}</td>
      <td class="{{ 'rsi-high' if p.rsi and p.rsi >= 70 else ('rsi-low' if p.rsi and p.rsi <= 35 else '') }}">
        {{ "%.0f"|format(p.rsi) if p.rsi else "—" }}
      </td>
      <td class="{{ 'pos' if p.ma20_diff and p.ma20_diff >= 0 else 'neg' }}">
        {{ "%.1f%%"|format(p.ma20_diff) if p.ma20_diff is not none else "—" }}
      </td>
      <td class="neg">{{ "%.2f"|format(p.stop_loss) }}</td>
      <td class="pos">{{ "%.2f"|format(p.target) }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>

{% if candidates %}
<h2>Momentum Scanner — Top {{ candidates|length }}</h2>
<table>
  <thead>
    <tr>
      <th>#</th><th>Ticker</th><th>Son Fiyat</th><th>Günlük</th>
      <th>1 Ay</th><th>Hacim Surge</th><th>52H Uzak.</th><th>RSI</th><th>Skor</th>
    </tr>
  </thead>
  <tbody>
  {% for c in candidates %}
    <tr>
      <td>{{ loop.index }}</td>
      <td class="ticker">{{ c.ticker }}</td>
      <td>{{ "%.2f"|format(c.close) }}</td>
      <td class="{{ 'pos' if c.daily_chg and c.daily_chg >= 0 else 'neg' }}">
        {{ c.daily_chg|pct if c.daily_chg is not none else "—" }}
      </td>
      <td class="{{ 'pos' if c.ret_1m and c.ret_1m >= 0 else 'neg' }}">
        {{ c.ret_1m|pct if c.ret_1m is not none else "—" }}
      </td>
      <td>{{ "%.1fx"|format(c.vol_surge) if c.vol_surge else "—" }}</td>
      <td>{{ "%.1f%%"|format(c.proximity_52w) if c.proximity_52w is not none else "—" }}</td>
      <td class="{{ 'rsi-high' if c.rsi and c.rsi >= 70 else ('rsi-low' if c.rsi and c.rsi <= 35 else '') }}">
        {{ "%.0f"|format(c.rsi) if c.rsi else "—" }}
      </td>
      <td>{{ "%.4f"|format(c.score) if c.score is not none else "—" }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

{% if alerts %}
<h2>Uyarılar</h2>
{% for al in alerts %}
<div class="alert-box {{ 'med' if al.severity == 'MEDIUM' else ('low' if al.severity == 'LOW' else '') }}">
  <span class="badge badge-{{ 'high' if al.severity == 'HIGH' else ('med' if al.severity == 'MEDIUM' else 'low') }}">
    {{ al.severity }}
  </span>
  &nbsp;<strong>{{ al.ticker }}</strong> — {{ al.message }}
</div>
{% endfor %}
{% endif %}

<footer>Bu rapor otomatik oluşturulmuştur. Yatırım tavsiyesi değildir.</footer>
</body>
</html>
